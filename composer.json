{
    "name": "taptap-pay/woocommerce",
    "description": "Official TapTap-Pay payment gateway for WooCommerce",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "homepage": "https://taptap.rs",
    "keywords": [
        "wordpress",
        "woocommerce",
        "payment-gateway",
        "taptap",
        "taptap-pay"
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "taptap-pay/sdk": "0.0.47",
        "yahnis-elsts/plugin-update-checker": "^5.6"
    },
    "extra": {
        "release-bump": {
            "_comment": "On every API release, .github/workflows/release-sdks.yml :: push_woocommerce regex-rewrites the `taptap-pay/sdk` constraint above to the new tag and bumps plugin-header version strings. Keep that line on its own without reformatting so the sed pattern keeps matching."
        }
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.10"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/TapTap-Pay/sdk-php"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "TapTap\\Pay\\WooCommerce\\": "includes/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.1"
        },
        "allow-plugins": {
            "composer/installers": false
        }
    }
}
